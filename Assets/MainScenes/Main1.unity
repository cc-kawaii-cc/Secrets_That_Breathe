  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::OfficeSequenceManager
  phase: 0
  sitPosition: {fileID: 311592130}
  standUpPosition: {fileID: 1746413895}
  interactAction: {fileID: 1781555164194001046, guid: 052faaac586de48259a63d0c4782560b, type: 3}
  eatPromptUI: {fileID: 901475379}
  doorCollider: {fileID: 1457596039}
  auntObject: {fileID: 1736476447}
  auntSpawnPoint: {fileID: 1252031125}
  auntStandPoint: {fileID: 694039246}
  auntRunSpeed: 3.5
  auntAnimator: {fileID: 0}
  auntRunBool: isRunning
  moneyObject: {fileID: 1840431540}
  pushHandQTE: {fileID: 4228010}
  eatingLine: "\u0E27\u0E31\u0E19\u0E19\u0E35\u0E49\u0E40\u0E1E\u0E34\u0E48\u0E07\u0E08\u0E30\u0E44\u0E14\u0E49\u0E19\u0E31\u0E48\u0E07\u0E01\u0E34\u0E19\u0E21\u0E32\u0E21\u0E48\u0E32\u0E14\u0E35\u0E46
    \u0E1A\u0E49\u0E32\u0E07 \u0E1B\u0E01\u0E15\u0E34\u0E41\u0E17\u0E1A\u0E44\u0E21\u0E48\u0E21\u0E35\u0E40\u0E27\u0E25\u0E32\u0E44\u0E14\u0E49\u0E19\u0E31\u0E48\u0E07\u0E01\u0E34\u0E19\u0E40\u0E25\u0E22"
  auntPleaLines:
  - "\u0E2B\u0E19\u0E39... \u0E2B\u0E19\u0E39\u0E43\u0E0A\u0E48\u0E17\u0E19\u0E32\u0E22\u0E40\u0E02\u0E49\u0E21\u0E43\u0E0A\u0E48\u0E21\u0E31\u0E49\u0E22\u0E25\u0E39\u0E01...
    \u0E0A\u0E48\u0E27\u0E22\u0E1B\u0E49\u0E32\u0E14\u0E49\u0E27\u0E22\u0E19\u0E30
    \u0E25\u0E39\u0E01\u0E2A\u0E32\u0E27\u0E1B\u0E49\u0E32... \u0E42\u0E14\u0E19\u0E23\u0E16\u0E0A\u0E19\u0E15\u0E32\u0E22"
  - "\u0E1B\u0E49\u0E32\u0E44\u0E1B\u0E41\u0E08\u0E49\u0E07\u0E04\u0E27\u0E32\u0E21\u0E41\u0E25\u0E49\u0E27...
    \u0E41\u0E15\u0E48\u0E15\u0E33\u0E23\u0E27\u0E08\u0E40\u0E02\u0E32\u0E44\u0E21\u0E48\u0E23\u0E31\u0E1A\u0E41\u0E08\u0E49\u0E07
    \u0E1A\u0E2D\u0E01\u0E27\u0E48\u0E32\u0E04\u0E39\u0E48\u0E01\u0E23\u0E13\u0E35\u0E40\u0E1B\u0E47\u0E19\u0E25\u0E39\u0E01
    \u0E2A.\u0E2A. ... \u0E2A\u0E38\u0E14\u0E17\u0E49\u0E32\u0E22\u0E40\u0E02\u0E32\u0E2A\u0E23\u0E38\u0E1B\u0E27\u0E48\u0E32\u0E40\u0E1B\u0E47\u0E19\u0E41\u0E04\u0E48\u0E2D\u0E38\u0E1A\u0E31\u0E15\u0E34\u0E40\u0E2B\u0E15\u0E38"
  - "\u0E1B\u0E49\u0E32\u0E40\u0E2B\u0E25\u0E37\u0E2D\u0E40\u0E07\u0E34\u0E19\u0E2D\u0E22\u0E39\u0E48\u0E41\u0E04\u0E48\u0E19\u0E35\u0E49...
    \u0E1B\u0E49\u0E32\u0E02\u0E2D\u0E08\u0E49\u0E32\u0E07\u0E2B\u0E19\u0E39\u0E19\u0E30
    \u0E0A\u0E48\u0E27\u0E22\u0E25\u0E39\u0E01\u0E1B\u0E49\u0E32\u0E2B\u0E19\u0E48\u0E2D\u0E22\u0E19\u0E30\u0E25\u0E39\u0E01"
  khemRefuseLine: "\u0E40\u0E01\u0E47\u0E1A\u0E40\u0E07\u0E34\u0E19\u0E44\u0E27\u0E49\u0E17\u0E33\u0E28\u0E1E\u0E19\u0E49\u0E2D\u0E07\u0E40\u0E16\u0E2D\u0E30\u0E1B\u0E49\u0E32
    \u0E04\u0E14\u0E35\u0E19\u0E35\u0E49\u0E1C\u0E21\u0E17\u0E33\u0E43\u0E2B\u0E49\u0E1F\u0E23\u0E35...
    \u0E1C\u0E21\u0E2A\u0E31\u0E0D\u0E0D\u0E32\u0E27\u0E48\u0E32\u0E08\u0E30\u0E25\u0E32\u0E01\u0E04\u0E2D\u0E21\u0E31\u0E19\u0E21\u0E32\u0E40\u0E02\u0E49\u0E32\u0E04\u0E38\u0E01\u0E43\u0E2B\u0E49\u0E44\u0E14\u0E49"
  lineDuration: 6
